VITE_API_BASE_URL=http://127.0.0.1:8000
VITE_WS_URL=ws://127.0.0.1:8000/ws/attacks
VITE_ENABLE_WS=true
# 兼容旧配置：未配置 VITE_MAP_DARK_TILE_URL 时，暗色模式会使用此地址。
VITE_MAP_TILE_URL=https://{s}.basemaps.cartocdn.com/dark_nolabels/{z}/{x}/{y}{r}.png
VITE_MAP_TILE_ATTRIBUTION="地图数据 &copy; <a href=\"https://www.openstreetmap.org/copyright\">OpenStreetMap 贡献者</a>，底图 &copy; <a href=\"https://carto.com/\">CARTO</a>"
VITE_MAP_DARK_TILE_URL=https://{s}.basemaps.cartocdn.com/dark_nolabels/{z}/{x}/{y}{r}.png
VITE_MAP_LIGHT_TILE_URL=https://{s}.basemaps.cartocdn.com/light_nolabels/{z}/{x}/{y}{r}.png
VITE_MAP_DARK_TILE_ATTRIBUTION=
VITE_MAP_LIGHT_TILE_ATTRIBUTION=
# 可选：配置支持 Leaflet 的透明中文注记瓦片；留空时使用项目内置中文地名覆盖层。
VITE_MAP_LABEL_TILE_URL=
VITE_MAP_DARK_LABEL_TILE_URL=
VITE_MAP_LIGHT_LABEL_TILE_URL=
VITE_MAP_LABEL_ATTRIBUTION=
VITE_MAP_PROVIDER_KEY=
VITE_MAP_LABEL_SUBDOMAINS=abc
